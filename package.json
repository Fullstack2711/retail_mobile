{
  "name": "retail",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "bash scripts/run-android.sh",
    "ios": "bash scripts/run-ios.sh",
    "lint": "eslint .",
    "start": "react-native start",
    "test": "jest",
    "postinstall": "node scripts/patch-gesture-handler.js && node scripts/patch-gradle-foojay.js && node scripts/patch-glog-xcode-spaces.js",
    "icons": "bash scripts/generate-app-icons.sh",
    "keystore:android": "bash scripts/create-android-keystore.sh",
    "build:android": "bash scripts/build-android-release.sh",
    "build:android:aab": "cd android && ./gradlew bundleRelease",
    "build:android:apk": "cd android && ./gradlew assembleRelease",
    "build:ios": "bash scripts/build-ios-release.sh",
    "pods:ios": "bash -c 'export LANG=en_US.UTF-8 RCT_USE_RN_DEP=0 RCT_USE_PREBUILT_RNCORE=0 && cd ios && bundle exec pod install'"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^3.0.3",
    "@react-native-firebase/app": "^24.0.0",
    "@react-native-firebase/messaging": "^24.0.0",
    "@react-native/new-app-screen": "0.85.3",
    "@react-navigation/bottom-tabs": "^7.16.1",
    "@react-navigation/native": "^7.2.4",
    "@react-navigation/native-stack": "^7.15.1",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-bootsplash": "^7.3.1",
    "react-native-gesture-handler": "^2.31.2",
    "react-native-gifted-charts": "^1.4.76",
    "react-native-linear-gradient": "^2.8.3",
    "react-native-safe-area-context": "^5.5.2",
    "react-native-screens": "^4.25.0",
    "react-native-svg": "^15.15.5",
    "react-native-vector-icons": "^10.3.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.1.0",
    "@react-native-community/cli-platform-android": "20.1.0",
    "@react-native-community/cli-platform-ios": "20.1.0",
    "@react-native/babel-preset": "0.85.3",
    "@react-native/eslint-config": "0.85.3",
    "@react-native/jest-preset": "0.85.3",
    "@react-native/metro-config": "0.85.3",
    "@react-native/typescript-config": "0.85.3",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.2.0",
    "@types/react-test-renderer": "^19.1.0",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "prettier": "2.8.8",
    "react-native-asset": "^2.3.0",
    "react-native-make": "^1.0.1",
    "react-test-renderer": "19.2.3",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">= 22.11.0"
  }
}
