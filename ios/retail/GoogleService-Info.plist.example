<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Firebase Console → retail → retail_mobile (ios) → GoogleService-Info.plist yuklab oling.
  Faylni GoogleService-Info.plist deb saqlang (shu papkada).

  MUHIM: Bundle ID ilovadagi PRODUCT_BUNDLE_IDENTIFIER bilan bir xil bo‘lishi kerak.
  Hozirgi kod: com.retailsolution.uz
  Sizdagi Firebase (skrinshot): com.cradle.retailMobile — mos kelmaydi.

  Yechim: Firebase da yangi iOS app qo‘shing, Bundle ID = com.retailsolution.uz
-->
<plist version="1.0">
<dict>
  <key>CLIENT_ID</key>
  <string>REPLACE_ME</string>
  <key>REVERSED_CLIENT_ID</key>
  <string>REPLACE_ME</string>
  <key>API_KEY</key>
  <string>REPLACE_ME</string>
  <key>GCM_SENDER_ID</key>
  <string>458194550273</string>
  <key>PLIST_VERSION</key>
  <string>1</string>
  <key>BUNDLE_ID</key>
  <string>com.retailsolution.uz</string>
  <key>PROJECT_ID</key>
  <string>retail-56f9a</string>
  <key>STORAGE_BUCKET</key>
  <string>retail-56f9a.firebasestorage.app</string>
  <key>IS_ADS_ENABLED</key>
  <false/>
  <key>IS_ANALYTICS_ENABLED</key>
  <false/>
  <key>IS_APPINVITE_ENABLED</key>
  <true/>
  <key>IS_GCM_ENABLED</key>
  <true/>
  <key>IS_SIGNIN_ENABLED</key>
  <true/>
  <key>GOOGLE_APP_ID</key>
  <string>1:458194550273:ios:REPLACE_ME</string>
</dict>
</plist>
